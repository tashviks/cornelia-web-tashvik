# Environment Variables Example
# Copy this file to .env.local and update with your actual values

# Website Configuration
NEXT_PUBLIC_SITE_NAME="Project Cornelia AINA Foundation"
NEXT_PUBLIC_SITE_URL="https://cornelia-foundation.org"
NEXT_PUBLIC_CONTACT_EMAIL="contact@corneliafoundation.org"

# Social Media Links
NEXT_PUBLIC_INSTAGRAM_URL="https://www.instagram.com/project.cornelia/"
NEXT_PUBLIC_LINKEDIN_URL="https://www.linkedin.com/company/project-cornelia/"

# External Forms & Links
NEXT_PUBLIC_WORK_WITH_US_FORM="https://forms.gle/auEAXJ96GoRzLPmr9"
NEXT_PUBLIC_WRITE_FOR_US_FORM="https://forms.gle/dx3ERQHoTLGF1pcx8"
NEXT_PUBLIC_DONATE_LINK="https://milaap.org/fundraisers/plc-ahaana-againstacid"

# Email Service (Optional - for contact form)
# NEXT_PUBLIC_EMAILJS_SERVICE_ID=""
# NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=""
# NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=""

# Analytics (Optional)
# NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=""
# NEXT_PUBLIC_HOTJAR_ID=""

# API Configuration (Optional - for form submissions)
# API_URL="https://api.example.com"
# API_KEY=""
